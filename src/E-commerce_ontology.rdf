    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#OutOfStockProduct -->

    <owl:Class rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#OutOfStockProduct">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Physical"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#stockQuantity"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Physical"/>
    </owl:Class>
    


