<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4/"
     xml:base="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:matti="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#StarRating -->

    <rdfs:Datatype rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#StarRating">
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <owl:withRestrictions rdf:parseType="Collection">
                    <rdf:Description>
                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</xsd:minInclusive>
                    </rdf:Description>
                    <rdf:Description>
                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</xsd:maxInclusive>
                    </rdf:Description>
                </owl:withRestrictions>
            </rdfs:Datatype>
        </owl:equivalentClass>
    </rdfs:Datatype>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#boughtBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#boughtBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#purchased"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Product"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#contains -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#contains">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Product"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#deliveredTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#deliveredTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#PhysicalOrder"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#DeliveryDestination"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#downloadableBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#downloadableBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Digital"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasBalance -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasBalance">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Balance"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasLifecycle -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasLifecycle">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Lifecycle"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#livesIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#livesIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Location"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#managedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#managedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Warehouse"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#orderOriginatesFrom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#orderOriginatesFrom">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Location"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#placedBy"/>
            <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#livesIn"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#paidWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#paidWith">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Payment"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#placedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#placedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#purchased -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#purchased">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Product"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#receivesSupportFrom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#receivesSupportFrom">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Support"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#requiresShipping -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#requiresShipping">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#PhysicalOrder"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#DeliveryDestination"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#sells -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#sells">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#soldBy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Product"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#shippedFrom -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#shippedFrom">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#PhysicalOrder"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Warehouse"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#soldBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#soldBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Product"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#storedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#storedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Physical"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Warehouse"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#accountBalance -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#accountBalance">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Balance"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#cancellationReason -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#cancellationReason">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Cancelled"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#cityName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#cityName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#companyName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#companyName">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Corporate"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#downloadSizeMB -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#downloadSizeMB">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Digital"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#estimatedDeliveryDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#estimatedDeliveryDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#PhysicalOrder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#expireDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#expireDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Perishable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#firstName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#firstName">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Human"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Individual"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasEmail -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasEmail">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasOrderID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasOrderID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasPassword -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasPassword">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Buyer"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasPrice -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasPrice">
