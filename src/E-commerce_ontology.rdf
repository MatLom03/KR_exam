        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#downloadSizeMB"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Physical"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#DigitalOrder -->

    <owl:Class rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#DigitalOrder">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#contains"/>
                        <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Digital"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Order"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#contains"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Digital"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


