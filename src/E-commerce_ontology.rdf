        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasVATnumber -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#hasVATnumber">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Corporate"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#lastName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#lastName">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Human"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Individual"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/matti/ontologies/2026/0/untitled-ontology-4#Seller"/>
